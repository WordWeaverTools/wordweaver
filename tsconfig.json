{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@everyvoice/every-voice": ["../dist/every-voice"]
    },
    "baseUrl": "./src",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "module": "es2020",
    "target": "ES2022",
    "typeRoots": ["node_modules/@types", "node_modules/echarts/types/dist"],
    "lib": ["es2018", "dom"],
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "strictInjectionParameters": true
  }
}
