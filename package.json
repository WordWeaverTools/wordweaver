    },
    {
      "name": "Delasie Torkornoo",
      "email": "delasie.torkornoo@nrc-cnrc.gc.ca"
    }
  ],
  "maintainers": [
    {
      "name": "Aidan Pine",
      "email": "aidan.pine@nrc-cnrc.gc.ca"
    },
    {
      "name": "Eric Joanis",
      "email": "eric.joanis@nrc-cnrc.gc.ca"
    },
    {
      "name": "Delaney Lothian",
      "email": "delaney.lothian@nrc-cnrc.gc.ca"
    },
    {
      "name": "Delasie Torkornoo",
      "email": "delasie.torkornoo@nrc-cnrc.gc.ca"
    }
  ],
  "keywords": [
    "angular",
    "angular 8",
    "electron",
    "typescript",
    "eslint",
    "spectron",
    "sass",
    "language"
  ],
  "main": "main.js",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "ng build every-voice && ng build",
    "build-ev": "ng build every-voice",
    "build-toy": "ng build --outputPath ./dist_toy",
    "heroku-postbuild": "echo 'no-op'",
    "lint": "ng lint",
    "test": "ng lint && ng test --configuration=test --watch=false",
    "ci:test": "ng test --browsers=ChromeHeadless --watch=false --configuration=test",
    "watch": "ng test --configuration=test --browsers ChromeHeadless --watch --reporters dots",
    "release": "standard-version && git push --follow-tags origin master",
    "format:write": "prettier 'projects/**/*.{ts,json,md,scss,html}' --write",
    "format:test": "prettier 'projects/**/*.{ts,json,md,scss,html}' --list-different",
    "ci:build:ghpages": "ng build every-voice && ng build --configuration=production,ghpages --deploy-url /wordweaver/ --base-href /wordweaver/",
    "ci:build:netlify": "ng build every-voice && ng build --configuration=production,netlify --base-href / --deploy-url /",
    "analyze": "npm run build:netlify -- --stats-json && webpack-bundle-analyzer ./dist/word-weaver/stats-es2015.json",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate && node .all-contributors-html.js",
    "contributors:check": "all-contributors check",
    "tslint-check": "tslint-config-prettier-check ./tslint.json",
    "extract-translations": "ngx-translate-extract --input ./projects/word-weaver/src --output ./projects/word-weaver/src/assets/i18n/*.json --sort --format namespaced-json --null-as-default-value && prettier --write ./projects/word-weaver/src/assets/i18n/*.json",
    "update-translations": "./update_translations.sh",
    "postinstall": "ng build every-voice || true",
    "compress": "cd ./projects/word-weaver-cli && npm run-script compress",
    "generate-schemas": "cd ./projects/word-weaver-cli && npm run-script generate-schemas",
    "validate": "cd ./projects/word-weaver-cli && npm run-script validate",
    "validate-and-compress": "cd ./projects/word-weaver-cli && npm run-script validate && npm run-script compress",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --project chromium --headed"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.15",
    "@angular-eslint/builder": "14.4.0",
    "@angular-eslint/eslint-plugin": "14.4.0",
    "@angular-eslint/eslint-plugin-template": "14.4.0",
    "@angular-eslint/schematics": "18.4.3",
    "@angular-eslint/template-parser": "14.4.0",
    "@angular/animations": "^20.3.16",
    "@angular/build": "^20.3.15",
    "@angular/cdk": "^20.2.14",
    "@angular/cli": "^20.3.15",
    "@angular/common": "^20.3.16",
    "@angular/compiler": "^20.3.16",
    "@angular/compiler-cli": "^20.3.16",
    "@angular/core": "^20.3.16",
    "@angular/forms": "^20.3.16",
    "@angular/language-service": "^20.3.16",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.16",
    "@angular/platform-browser-dynamic": "^20.3.16",
    "@angular/router": "^20.3.16",
    "@angular/service-worker": "^20.3.16",
    "@colsen1991/ngx-translate-extract-marker": "^2.0.8",
    "@commitlint/cli": "^16.3.0",
    "@commitlint/config-conventional": "^16.2.4",
    "@fortawesome/angular-fontawesome": "^0.10.0",
    "@fortawesome/fontawesome-free": "^5.12.1",
    "@fortawesome/fontawesome-svg-core": "^1.2.27",
    "@fortawesome/free-brands-svg-icons": "^5.12.1",
    "@fortawesome/free-solid-svg-icons": "^5.12.1",
    "@ngrx/effects": "^20.0.0",
    "@ngrx/entity": "^20.0.0",
    "@ngrx/router-store": "^20",
    "@ngrx/store": "^20.0.0",
    "@ngrx/store-devtools": "^20.0.0",
    "@ngx-translate/core": "14.0.0",
    "@ngx-translate/http-loader": "4.0.0",
    "@playwright/test": "^1.39.0",
    "@types/file-saver-es": "^2.0.1",
    "@types/jasmine": "3.3.16",
    "@types/jasminewd2": "2.0.8",
    "@types/mocha": "5.2.7",
    "@types/node": "20.14.8",
    "@types/uuid": "^3.4.7",
    "@typescript-eslint/eslint-plugin": "^6",
    "@typescript-eslint/parser": "^6",
    "@vendure/ngx-translate-extract": "^8.2.3",
    "bootstrap": "^4.4.1",
    "browser-detect": "^0.2.28",
    "chai": "4.2.0",
    "conventional-changelog-cli": "^3.0.0",
    "core-js": "3.23.3",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsdoc": "41.1.2",
    "eslint-plugin-prefer-arrow": "latest",
    "eslint-plugin-react": "latest",
    "express": "^4.16.4",
    "husky": "^4.2.1",
    "jasmine-core": ">=3.8",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.1",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-electron": "^7.3.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "karma-spec-reporter": "0.0.32",
    "madge": "^4.0.2",
    "mocha": "^10.2.0",
    "monocart-reporter": "^1.7.13",
    "ng-packagr": "^20.3.2",
    "npm-run-all": "4.1.5",
    "peaks.js": "^0.19.0",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "protractor": "~7.0.0",
    "rimraf": "^3.0.2",
    "rxjs": "6.5.5",
    "spectron": "^19.0.0",
    "standard-version": "^9.5.0",
    "tslib": "^2.0.0",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "5.8.3",
    "uuid": "^3.4.0",
    "v8-to-istanbul": "^9.1.3",
    "webdriver-manager": "12.1.7",
    "webpack-bundle-analyzer": "^4.9.0",
    "word-weaver-cli": "file:projects/word-weaver-cli",
    "zone.js": "0.15.1"
  },
  "engines": {
